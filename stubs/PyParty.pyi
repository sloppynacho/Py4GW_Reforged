    def __init__(self, agent_id: int = 0, owner_player_id: int = 0, hero_id: int = 0, level: int = 0) -> None: ...

class HenchmanPartyMember:
    agent_id: int
    profession: int
    level: int
    def __init__(self, agent_id: int = 0, profession: int = 0, level: int = 0) -> None: ...

class PetInfo:
