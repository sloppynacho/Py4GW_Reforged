    called_target_id: int
    is_connected: bool
    is_ticked: bool
    def __init__(self, login_number: int = 0, called_target_id: int = 0, is_connected: bool = False, is_ticked: bool = False) -> None: ...

class HeroPartyMember:
    agent_id: int
    owner_player_id: int
